<div class="max-w-3xl mx-auto px-6 py-12">
  <h1 class="text-3xl font-bold mb-10">Your Profile</h1>

  <div class="bg-white rounded-xl shadow-md p-8">
    <form action="/profile" method="POST" class="space-y-6">
      <div class="grid grid-cols-2 gap-6">
        <div>
          <label class="block text-sm font-medium mb-1">First Name</label>
          <input type="text" name="firstName" value="<%= user.firstName %>" required class="block w-full border-gray-300 rounded-md shadow-sm focus:border-red-500 focus:ring-red-500"/>
        </div>
        <div>
          <label class="block text-sm font-medium mb-1">Last Name</label>
          <input type="text" name="lastName" value="<%= user.lastName %>" required class="block w-full border-gray-300 rounded-md shadow-sm focus:border-red-500 focus:ring-red-500"/>
        </div>
      </div>

      <div>
        <label class="block text-sm font-medium mb-1">Email</label>
        <input type="email" value="<%= user.email %>" disabled class="block w-full border-gray-300 rounded-md bg-gray-100"/>
      </div>

      <div>
        <label class="block text-sm font-medium mb-1">Phone Number</label>
        <input type="tel" name="phone" value="<%= user.phone || '' %>" class="block w-full border-gray-300 rounded-md shadow-sm focus:border-red-500 focus:ring-red-500"/>
      </div>

      <div>
        <label class="block text-sm font-medium mb-1">Address</label>
        <textarea name="address" rows="2" class="block w-full border-gray-300 rounded-md shadow-sm focus:border-red-500 focus:ring-red-500"><%= user.address || '' %></textarea>
      </div>

      <div class="pt-4 space-y-4">
        <label class="flex items-center">
          <input type="checkbox" name="emailOptIn" <%= user.emailOptIn ? 'checked' : '' %> class="h-4 w-4 text-red-600 focus:ring-red-500 border-gray-300 rounded"/>
          <span class="ml-2">Receive email updates & newsletters</span>
        </label>
        <label class="flex items-center">
          <input type="checkbox" name="smsOptIn" <%= user.smsOptIn ? 'checked' : '' %> class="h-4 w-4 text-red-600 focus:ring-red-500 border-gray-300 rounded"/>
          <span class="ml-2">Receive SMS notifications</span>
        </label>
      </div>

      <button type="submit" class="w-full bg-red-600 text-white py-3 rounded-md font-medium hover:bg-red-700 mt-8">
        Save Changes
      </button>
    </form>
  </div>
</div>