<%- include('layout') %>

<div class="max-w-lg mx-auto mt-12 px-6 py-12 bg-white rounded-xl shadow-md">
  <h2 class="text-3xl font-bold mb-10 text-center">Create Account</h2>

  <form action="/signup" method="POST" class="space-y-6">
    <div class="grid grid-cols-2 gap-6">
      <div>
        <label class="block text-sm font-medium mb-1">First Name</label>
        <input type="text" name="firstName" required class="block w-full border-gray-300 rounded-md shadow-sm focus:border-red-500 focus:ring-red-500"/>
      </div>
      <div>
        <label class="block text-sm font-medium mb-1">Last Name</label>
        <input type="text" name="lastName" required class="block w-full border-gray-300 rounded-md shadow-sm focus:border-red-500 focus:ring-red-500"/>
      </div>
    </div>

    <div>
      <label class="block text-sm font-medium mb-1">Email Address</label>
      <input type="email" name="email" required class="block w-full border-gray-300 rounded-md shadow-sm focus:border-red-500 focus:ring-red-500"/>
    </div>

    <div>
      <label class="block text-sm font-medium mb-1">Phone Number (optional)</label>
      <input type="tel" name="phone" class="block w-full border-gray-300 rounded-md shadow-sm focus:border-red-500 focus:ring-red-500"/>
    </div>

    <div>
      <label class="block text-sm font-medium mb-1">Date of Birth <span class="text-gray-500 text-xs">(13+ required)</span></label>
      <input type="date" name="dateOfBirth" required class="block w-full border-gray-300 rounded-md shadow-sm focus:border-red-500 focus:ring-red-500"/>
    </div>

    <div>
      <label class="block text-sm font-medium mb-1">Password</label>
      <input type="password" name="password" required minlength="8" class="block w-full border-gray-300 rounded-md shadow-sm focus:border-red-500 focus:ring-red-500"/>
    </div>

    <div class="space-y-3 pt-4">
      <label class="flex items-center">
        <input type="checkbox" name="emailOptIn" class="h-4 w-4 text-red-600 focus:ring-red-500 border-gray-300 rounded"/>
        <span class="ml-2 text-sm">Receive email updates & newsletters</span>
      </label>
      <label class="flex items-center">
        <input type="checkbox" name="smsOptIn" class="h-4 w-4 text-red-600 focus:ring-red-500 border-gray-300 rounded"/>
        <span class="ml-2 text-sm">Receive SMS notifications (carrier charges may apply)</span>
      </label>
    </div>

    <button type="submit" class="w-full bg-red-600 text-white py-3 rounded-md font-medium hover:bg-red-700 transition mt-6">
      Create Account
    </button>
  </form>

  <div class="mt-8 text-center text-sm">
    <p>Already have an account? <a href="/login" class="text-red-600 hover:underline">Sign in</a></p>
    <p class="mt-4">Or sign in with:</p>
    <a href="/auth/google" class="mt-3 inline-flex items-center bg-white border border-gray-300 px-6 py-3 rounded-md hover:bg-gray-50">
      <i class="fab fa-google text-red-600 mr-3 text-xl"></i> Continue with Google
    </a>
  </div>
</div>