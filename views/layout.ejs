<!DOCTYPE html>
<html lang="en" data-theme="system">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>X Conservatives United</title>
    <link rel="stylesheet" href="/css/style.css">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</head>
<body>
    <nav class="navbar">
        <div class="nav-container">
            <a href="/" class="logo">XCU</a>
            
            <div class="nav-links">
                <% if (typeof user !== 'undefined' && user) { %>
                    <span class="nav-user">Welcome, <%= user.first_name || user.email %></span>
                    <% if (user.is_admin) { %>
                        <a href="/admin" class="nav-btn admin-btn">Admin Panel</a>
                    <% } %>
                    <a href="/logout" class="nav-btn logout-btn">Logout</a>
                <% } else { %>
                    <a href="/login" class="nav-btn">Login</a>
                    <a href="/register" class="nav-btn primary">Register</a>
                <% } %>
                
                <!-- Theme Toggle -->
                <button id="theme-toggle" class="theme-toggle" aria-label="Toggle theme">
                    <span class="sun">☀️</span>
                    <span class="moon">🌙</span>
                </button>
            </div>
        </div>
    </nav>

    <main class="main-content">
        <%- body %>
    </main>

    <script>
        // Light/Dark mode with system preference + toggle
        const toggle = document.getElementById('theme-toggle');
        const html = document.documentElement;

        function setTheme(theme) {
            if (theme === 'dark') {
                html.setAttribute('data-theme', 'dark');
                localStorage.setItem('theme', 'dark');
            } else if (theme === 'light') {
                html.setAttribute('data-theme', 'light');
                localStorage.setItem('theme', 'light');
            } else {
                html.setAttribute('data-theme', 'system');
                localStorage.removeItem('theme');
            }
        }

        // Load saved preference or respect system
        const savedTheme = localStorage.getItem('theme');
        if (savedTheme) {
            html.setAttribute('data-theme', savedTheme);
        } else {
            const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
            html.setAttribute('data-theme', prefersDark ? 'dark' : 'light');
        }

        // Toggle handler
        toggle.addEventListener('click', () => {
            const current = html.getAttribute('data-theme');
            if (current === 'dark') setTheme('light');
            else if (current === 'light') setTheme('dark');
            else setTheme('dark');
        });
    </script>
</body>
</html>