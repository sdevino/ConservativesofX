<!DOCTYPE html>
<html lang="en" class="scroll-smooth" x-data="{ darkMode: localStorage.getItem('theme') || 'system' }" 
      :class="{ 'dark': darkMode === 'dark' || (darkMode === 'system' && window.matchMedia('(prefers-color-scheme: dark)').matches) }">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Conservatives of X</title>
  
  <!-- Tailwind output – this is the critical line you asked to add / confirm -->
  <link rel="stylesheet" href="/css/output.css">
  
  <!-- Alpine.js for theme toggle reactivity (lightweight) -->
  <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
  
  <script>
    // Theme persistence + system preference listener
    document.addEventListener('alpine:init', () => {
      Alpine.store('theme', {
        init() {
          const saved = localStorage.getItem('theme') || 'system';
          this.current = saved;
          this.apply();
          
          window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', e => {
            if (this.current === 'system') this.apply();
          });
        },
        current: 'system',
        toggle() {
          this.current = this.current === 'dark' ? 'light' : 
                        this.current === 'light' ? 'system' : 'dark';
          localStorage.setItem('theme', this.current);
          this.apply();
        },
        apply() {
          if (this.current === 'dark' || 
             (this.current === 'system' && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            document.documentElement.classList.add('dark');
          } else {
            document.documentElement.classList.remove('dark');
          }
        }
      });
    });
  </script>
</head>
<body class="min-h-screen flex flex-col transition-colors duration-300">
  <header class="sticky top-0 z-50 bg-white/80 dark:bg-slate-900/80 backdrop-blur-md border-b border-gray-200 dark:border-gray-800">
    <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex justify-between items-center">
      <a href="/" class="text-2xl font-bold text-primary-600 dark:text-red-500">Conservatives of X</a>
      
      <div class="flex items-center space-x-8">
        <div class="hidden md:flex space-x-6 text-sm font-medium">
          <a href="/" class="hover:text-primary-600 dark:hover:text-red-400 transition">Home</a>
          <a href="/about" class="hover:text-primary-600 dark:hover:text-red-400 transition">About</a>
          <a href="/events" class="hover:text-primary-600 dark:hover:text-red-400 transition">Events</a>
          <a href="/community" class="hover:text-primary-600 dark:hover:text-red-400 transition">Community</a>
          <a href="/donate" class="hover:text-primary-600 dark:hover:text-red-400 transition">Donate</a>
          <a href="/contact" class="hover:text-primary-600 dark:hover:text-red-400 transition">Contact</a>
        </div>

        <div class="flex items-center space-x-4">
          <% if (user) { %>
            <a href="/profile" class="text-sm font-medium hover:text-primary-600 dark:hover:text-red-400"><%= user.firstName %></a>
            <% if (user.isAdmin) { %>
              <a href="/admin" class="text-sm font-medium text-primary-600 dark:text-red-400">Admin</a>
            <% } %>
            <a href="/logout" class="text-sm text-red-600 hover:text-red-800 dark:text-red-400">Logout</a>
          <% } else { %>
            <a href="/login" class="text-sm font-medium hover:text-primary-600 dark:hover:text-red-400">Login</a>
            <a href="/signup" class="btn-primary text-sm">Sign Up</a>
          <% } %>

          <!-- Theme Toggle Button -->
          <button 
            @click="$store.theme.toggle()" 
            class="theme-toggle p-2 rounded-full hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors"
            aria-label="Toggle theme"
            title="Toggle dark/light/system mode"
          >
            <span x-show="$store.theme.current === 'light'" class="text-xl">☀️</span>
            <span x-show="$store.theme.current === 'dark'" class="text-xl">🌙</span>
            <span x-show="$store.theme.current === 'system'" class="text-xl">⚙️</span>
          </button>
        </div>
      </div>
    </nav>
  </header>

  <main class="flex-grow">
    <%- body %>
  </main>

  <footer class="bg-slate-900 text-slate-300 py-8 text-center text-sm border-t border-slate-800">
    <p>&copy; <%= new Date().getFullYear() %> Conservatives of X. All rights reserved.</p>
  </footer>
</body>
</html>