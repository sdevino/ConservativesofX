<div class="max-w-md mx-auto mt-16 px-6 py-12 bg-white rounded-xl shadow-md">
  <h2 class="text-3xl font-bold mb-10 text-center">Sign In</h2>

  <form action="/login" method="POST" class="space-y-6">
    <div>
      <label class="block text-sm font-medium mb-1">Email</label>
      <input type="email" name="email" required class="block w-full border-gray-300 rounded-md shadow-sm focus:border-red-500 focus:ring-red-500"/>
    </div>

    <div>
      <label class="block text-sm font-medium mb-1">Password</label>
      <input type="password" name="password" required class="block w-full border-gray-300 rounded-md shadow-sm focus:border-red-500 focus:ring-red-500"/>
    </div>

    <button type="submit" class="w-full bg-red-600 text-white py-3 rounded-md font-medium hover:bg-red-700 transition">
      Sign In
    </button>
  </form>

  <div class="mt-8 text-center text-sm">
    <p>Or sign in with:</p>
    <a href="/auth/google" class="mt-4 inline-flex items-center bg-white border border-gray-300 px-8 py-3 rounded-md hover:bg-gray-50">
      <i class="fab fa-google text-red-600 mr-3 text-xl"></i> Google
    </a>
    <p class="mt-6">
      Don't have an account? <a href="/signup" class="text-red-600 hover:underline">Sign up</a>
    </p>
  </div>
</div>