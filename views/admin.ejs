<h1 class="mb-4">Admin Panel - User Management</h1>

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Date of Birth</th>
                    <th>Admin</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% users.forEach(user => { %>
                <tr>
                    <td><%= user.id %></td>
                    <td><%= user.first_name %> <%= user.last_name %></td>
                    <td><%= user.email %></td>
                    <td><%= user.date_of_birth.toISOString().split('T')[0] %></td>
                    <td>
                        <span class="badge <%= user.is_admin ? 'bg-success' : 'bg-secondary' %>">
                            <%= user.is_admin ? 'Yes' : 'No' %>
                        </span>
                    </td>
                    <td>
                        <button class="btn btn-sm btn-primary" 
                                onclick="editUser(<%= JSON.stringify(user).replace(/"/g, '&quot;') %>)">
                            Edit
                        </button>
                    </td>
                </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
</div>

<!-- Edit User Modal -->
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Edit User</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="editForm" method="POST" enctype="multipart/form-data">
                <div class="modal-body">
                    <input type="hidden" name="id" id="edit-id">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <input type="text" name="first_name" id="edit-first_name" class="form-control" placeholder="First Name" required>
                        </div>
                        <div class="col-md-6">
                            <input type="text" name="last_name" id="edit-last_name" class="form-control" placeholder="Last Name" required>
                        </div>
                        <div class="col-md-6">
                            <input type="email" name="email" id="edit-email" class="form-control" readonly>
                        </div>
                        <div class="col-md-6">
                            <input type="date" name="date_of_birth" id="edit-date_of_birth" class="form-control" required>
                        </div>
                        <div class="col-12">
                            <input type="text" name="mailing_address" id="edit-mailing_address" class="form-control" placeholder="Mailing Address">
                        </div>
                        <div class="col-12">
                            <div class="form-check">
                                <input type="checkbox" name="is_admin" id="edit-is_admin" class="form-check-input">
                                <label class="form-check-label" for="edit-is_admin">Make this user an Admin</label>
                            </div>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Profile Photo (optional)</label>
                            <input type="file" name="profile_photo" class="form-control" accept="image/*">
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
function editUser(user) {
    document.getElementById('edit-id').value = user.id;
    document.getElementById('edit-first_name').value = user.first_name;
    document.getElementById('edit-last_name').value = user.last_name;
    document.getElementById('edit-email').value = user.email;
    document.getElementById('edit-date_of_birth').value = user.date_of_birth.toISOString().split('T')[0];
    document.getElementById('edit-mailing_address').value = user.mailing_address || '';
    document.getElementById('edit-is_admin').checked = user.is_admin;
    
    const modal = new bootstrap.Modal(document.getElementById('editModal'));
    modal.show();
}
</script>