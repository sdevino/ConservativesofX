<%- include('layout') %>

<div class="max-w-7xl mx-auto px-6 py-12">
  <h1 class="text-4xl font-bold mb-10">Administration</h1>

  <div class="grid lg:grid-cols-3 gap-10">
    <!-- Users -->
    <div>
      <h2 class="text-2xl font-bold mb-4">Users</h2>
      <div class="bg-white rounded-xl shadow overflow-hidden">
        <table class="min-w-full divide-y divide-gray-200">
          <thead class="bg-gray-50">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Name</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Email</th>
              <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Admin</th>
            </tr>
          </thead>
          <tbody class="bg-white divide-y divide-gray-200">
            <% users.forEach(u => { %>
              <tr>
                <td class="px-6 py-4 whitespace-nowrap"><%= u.firstName %> <%= u.lastName %></td>
                <td class="px-6 py-4 whitespace-nowrap"><%= u.email %></td>
                <td class="px-6 py-4 whitespace-nowrap"><%= u.isAdmin ? 'Yes' : 'No' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Events -->
    <div>
      <h2 class="text-2xl font-bold mb-4">Events</h2>
      <form action="/admin/event" method="POST" class="bg-white p-6 rounded-xl shadow space-y-4">
        <input type="text" name="title" placeholder="Event Title" required class="block w-full border-gray-300 rounded-md"/>
        <textarea name="description" placeholder="Description" rows="3" required class="block w-full border-gray-300 rounded-md"></textarea>
        <input type="datetime-local" name="dateTime" required class="block w-full border-gray-300 rounded-md"/>
        <input type="url" name="graphicUrl" placeholder="Image URL (optional)" class="block w-full border-gray-300 rounded-md"/>
        <button type="submit" class="bg-red-600 text-white px-6 py-2 rounded-md hover:bg-red-700">Create Event</button>
      </form>
    </div>

    <!-- Categories -->
    <div>
      <h2 class="text-2xl font-bold mb-4">Forum Categories</h2>
      <form action="/admin/category" method="POST" class="bg-white p-6 rounded-xl shadow space-y-4">
        <input type="text" name="name" placeholder="Category Name" required class="block w-full border-gray-300 rounded-md"/>
        <textarea name="description" placeholder="Description (optional)" rows="2" class="block w-full border-gray-300 rounded-md"></textarea>
        <button type="submit" class="bg-red-600 text-white px-6 py-2 rounded-md hover:bg-red-700">Create Category</button>
      </form>
    </div>
  </div>
</div>