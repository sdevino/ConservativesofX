<%- include('layout') %>

<div class="max-w-7xl mx-auto px-6 py-12">
  <h1 class="text-4xl font-bold mb-10">Community</h1>

  <div class="grid lg:grid-cols-3 gap-10">
    <!-- Org chart / Discord placeholder -->
    <div class="lg:col-span-1">
      <h2 class="text-2xl font-bold mb-6">Internal Structure</h2>
      <p class="text-gray-600">Regional organization chart coming soon...</p>
      <div class="mt-8">
        <h3 class="font-semibold">Discord</h3>
        <p class="text-sm text-gray-500">Join our private Discord server for real-time discussion.</p>
      </div>
    </div>

    <!-- Forum -->
    <div class="lg:col-span-2">
      <h2 class="text-2xl font-bold mb-6">Discussion</h2>

      <form action="/community/post" method="POST" class="mb-12 bg-white p-6 rounded-xl shadow">
        <select name="categoryId" class="block w-full border-gray-300 rounded-md mb-4" required>
          <option value="">Select category</option>
          <% categories.forEach(cat => { %>
            <option value="<%= cat.id %>"><%= cat.name %></option>
          <% }) %>
        </select>
        <input type="text" name="title" placeholder="Title (optional)" class="block w-full border-gray-300 rounded-md mb-4 px-4 py-2"/>
        <textarea name="content" rows="5" placeholder="Your message..." required class="block w-full border-gray-300 rounded-md mb-4 px-4 py-2"></textarea>
        <button type="submit" class="bg-red-600 text-white px-6 py-3 rounded-md hover:bg-red-700">Post</button>
      </form>

      <% categories.forEach(cat => { %>
        <div class="mb-10">
          <h3 class="text-2xl font-semibold mb-4"><%= cat.name %></h3>
          <% if (cat.posts.length === 0) { %>
            <p class="text-gray-500">No recent posts.</p>
          <% } else { %>
            <div class="space-y-4">
              <% cat.posts.forEach(post => { %>
                <div class="bg-white p-5 rounded-lg shadow-sm">
                  <p class="font-medium"><%= post.author.firstName %> <%= post.author.lastName %></p>
                  <p class="text-sm text-gray-500 mb-2">
                    <%= new Date(post.createdAt).toLocaleString() %>
                  </p>
                  <% if (post.title) { %>
                    <h4 class="font-semibold mb-1"><%= post.title %></h4>
                  <% } %>
                  <p class="text-gray-700"><%= post.content.substring(0, 280) %><%= post.content.length > 280 ? '...' : '' %></p>
                </div>
              <% }) %>
            </div>
          <% } %>
        </div>
      <% }) %>
    </div>
  </div>
</div>